# Database Configuration
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/rag_db

# Vector Store Configuration
VECTOR_STORE_TYPE=chroma
PERSIST_DIRECTORY=./data/vector_store

# Embedding Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# LLM Configuration (openai/anthropic/ollama/modelscope)
LLM_PROVIDER=openai

# ModelScope / DashScope (OpenAI Compatible API)
# API 文档: https://api-inference.modelscope.cn/v1
# 申请地址: https://modelscope.cn/profile/apikey
# 可用模型: deepseek-ai/DeepSeek-R1-Distill-Qwen-7B, Qwen/Qwen3-8B, etc.
# MODELSCOPE_API_KEY=ms-your-modelscope-api-key
# MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
# MODELSCOPE_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B

# Retrieval Configuration
TOP_K=5
SIMILARITY_THRESHOLD=0.7
VECTOR_WEIGHT=0.6
KEYWORD_WEIGHT=0.4

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# Redis Cache (Optional)
# REDIS_URL=redis://localhost:6379/0
# REDIS_TTL=3600

# Log Configuration
LOG_LEVEL=INFO
